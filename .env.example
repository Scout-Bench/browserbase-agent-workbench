BROWSERBASE_API_KEY=your_browserbase_api_key

# Optional: reuse an existing agent instead of creating one on setup
# BROWSERBASE_AGENT_ID=

# Supabase signed URL or public URL to a PDF resume (required for run)
RESUME_URL=https://your-project.supabase.co/storage/v1/object/sign/bucket/resume.pdf?token=...

# Defaults to the Revise Robotics Ashby application if unset
APPLICATION_URL=https://jobs.ashbyhq.com/reviserobotics/7b0426d4-cf8c-4fdf-98a8-5a0360706633/application

# Route the agent browser through Browserbase proxies (recommended)
USE_PROXIES=true
